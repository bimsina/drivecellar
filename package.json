{
  "name": "drivecellar",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint",
    "format": "prettier --write .",
    "check": "prettier --write . && eslint --fix",
    "auth:generate": "pnpm dlx @better-auth/cli generate --output ./src/db/schema/auth.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1030.0",
    "@daveyplate/better-auth-ui": "3.4.0",
    "@fontsource-variable/geist": "5.2.8",
    "@t3-oss/env-core": "0.13.11",
    "@tailwindcss/vite": "4.1.18",
    "@tanstack/react-devtools": "0.10.0",
    "@tanstack/react-form": "1.29.0",
    "@tanstack/react-query": "5.99.0",
    "@tanstack/react-query-devtools": "5.99.0",
    "@tanstack/react-router": "1.168.21",
    "@tanstack/react-router-devtools": "1.166.13",
    "@tanstack/react-router-ssr-query": "1.166.11",
    "@tanstack/react-start": "1.167.39",
    "@tanstack/router-plugin": "1.167.22",
    "@trpc/client": "11.11.0",
    "@trpc/server": "11.11.0",
    "@trpc/tanstack-react-query": "11.11.0",
    "better-auth": "1.6.3",
    "better-sqlite3": "12.9.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "drizzle-kit": "0.31.9",
    "drizzle-orm": "0.45.1",
    "emoji-picker-react": "4.18.0",
    "lucide-react": "1.8.0",
    "mime": "4.1.0",
    "radix-ui": "1.4.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-virtualized": "9.22.6",
    "shadcn": "4.2.0",
    "sonner": "2.0.7",
    "superjson": "2.2.2",
    "tailwind-merge": "3.0.2",
    "tailwindcss": "4.1.18",
    "tw-animate-css": "1.3.6",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/typography": "0.5.16",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/eslint-config": "0.4.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.0",
    "@types/better-sqlite3": "7.6.0",
    "@types/node": "25.6.0",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "17.4.2",
    "jsdom": "29.0.2",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vite": "8.0.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "core-js",
      "esbuild",
      "lightningcss",
      "unrs-resolver"
    ]
  }
}
